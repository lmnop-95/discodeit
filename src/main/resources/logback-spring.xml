<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logback Configuration
  - Console: Colored output with MDC context (requestId, requestMethod, requestUri)
  - File: Daily rolling with 30-day retention (.logs/application.log)
-->
<configuration>

    <conversionRule conversionWord="clr"
                    converterClass="org.springframework.boot.logging.logback.ColorConverter"/>

    <property name="LOG_PATH" value="./.logs"/>
    <property name="LOG_FILE_NAME" value="application"/>
    <property name="CONSOLE_LOG_PATTERN"
              value="%d{yy-MM-dd HH:mm:ss.SSS} [%thread] %clr(%-5level) %clr(%-36logger{36}){cyan} [%X{requestId} | %X{requestMethod} | %X{requestUri}] - %msg%n"/>
    <property name="FILE_LOG_PATTERN"
              value="%d{yy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %-36logger{36} [%X{requestId} | %X{requestMethod} | %X{requestUri}] - %msg%n"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${LOG_FILE_NAME}.log</file>
        <encoder>
            <pattern>${FILE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${LOG_FILE_NAME}-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
    </appender>

    <!-- Local Profile: Verbose logging for development -->
    <springProfile name="local">
        <logger name="com.sprint.mission.discodeit" level="DEBUG"/>
        <logger name="org.hibernate.SQL" level="OFF"/>
        <logger name="net.ttddyy.dsproxy.listener" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
<!--            <appender-ref ref="FILE"/>-->
        </root>
    </springProfile>

    <!-- Production Profile: Minimal logging -->
    <springProfile name="prod">
        <logger name="com.sprint.mission.discodeit" level="INFO"/>
        <logger name="org.hibernate.SQL" level="OFF"/>
        <logger name="net.ttddyy.dsproxy.listener" level="OFF"/>
        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>

    <!-- Test Profile: Console only, no file output -->
    <springProfile name="test">
        <logger name="com.sprint.mission.discodeit" level="DEBUG"/>
        <logger name="org.hibernate.SQL" level="OFF"/>
        <logger name="net.ttddyy.dsproxy.listener" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

</configuration>
